PORT=5000
NODE_ENV=development
USE_MEMORY_DB=true
MONGODB_URI=mongodb://127.0.0.1:27017/football-labeling
JWT_SECRET=change-this-to-a-long-random-secret
CLIENT_URL=http://localhost:5173

# Production frontend
# CLIENT_URL=https://crazylabel.us

# Local football clips folder (used when VPS storage is not configured)
VIDEO_DATA_DIR=D:\Bittensor\data

# Public URL where videos are served (nginx on VPS)
# VIDEO_BASE_URL=https://media.crazylabel.us

# Legacy alias for video URLs if VIDEO_BASE_URL is unset
# API_BASE_URL=https://media.crazylabel.us

# --- VPS auto-upload (Render backend → Linux VPS via SFTP) ---
# When set, admin uploads go straight to VPS and connect to MongoDB automatically.
# VPS_SSH_HOST=YOUR_VPS_IP_OR_media.crazylabel.us
# VPS_SSH_PORT=22
# VPS_SSH_USER=root
# VPS_VIDEO_DIR=/var/www/football-clips
# Paste private key with \n for newlines, or use VPS_SSH_PASSWORD instead
# VPS_SSH_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----

# Reference annotations for scoring (local path or future VPS path)
# ANNOTATIONS_DIR=D:\Bittensor\annotations

# Optional: comma-separated extra origins
# ALLOWED_ORIGINS=https://my-app.vercel.app
