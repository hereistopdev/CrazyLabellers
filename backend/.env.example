PORT=5000
NODE_ENV=development

# Always use MongoDB Atlas (local dev uses the same database as production/staging).
USE_MEMORY_DB=false
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/football-labeling?retryWrites=true&w=majority

JWT_SECRET=change-this-to-a-long-random-secret
CLIENT_URL=http://localhost:5173

# Production frontend — use the URL users actually open in the browser.
# Comma-separate multiple URLs if needed (custom domain + Vercel URL):
# CLIENT_URL=https://crazylabel.us,https://your-app.vercel.app

# Videos are served from VPS (not local disk) when VPS_* vars are set:
# VIDEO_BASE_URL=https://media.crazylabel.us
# VPS_SSH_HOST=your-vps-ip
# VPS_SSH_PORT=22
# VPS_SSH_USER=administrator
# VPS_SSH_PASSWORD=...
# VPS_VIDEO_DIR=/var/www/football-clips

# Optional: only if VPS is not configured (fallback local clip folder)
# VIDEO_DATA_DIR=D:\Bittensor\data
# ANNOTATIONS_DIR=D:\Bittensor\annotations

# Optional: comma-separated extra origins
# ALLOWED_ORIGINS=https://preview-branch.vercel.app

# Optional: allow any https origin on these hostnames (and subdomains)
# CORS_ALLOWED_DOMAINS=crazylabel.us

# Only auto-classify uploaded clips as pre-test/production on startup when true.
# Leave unset/false so admin-marked tutorials are never overwritten.
# AUTO_SETUP_PRETEST=true

# Labeling help chatbot (OpenAI)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
