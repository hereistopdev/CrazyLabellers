PORT=5000
NODE_ENV=development
USE_MEMORY_DB=true
MONGODB_URI=mongodb://127.0.0.1:27017/football-labeling
JWT_SECRET=change-this-to-a-long-random-secret
CLIENT_URL=http://localhost:5173

# Production: your live frontend URL (custom domain or Vercel), no trailing slash
# CLIENT_URL=https://crazylabel.us
# ALLOWED_ORIGINS=https://www.crazylabel.us

# Local football clips folder (sibling to Labeling/, e.g. D:\Bittensor\data)
VIDEO_DATA_DIR=D:\Bittensor\data
# API_BASE_URL=http://localhost:5000

# Optional: comma-separated extra origins (e.g. Vercel preview URLs)
# ALLOWED_ORIGINS=https://my-app.vercel.app,https://my-app-git-main.vercel.app
